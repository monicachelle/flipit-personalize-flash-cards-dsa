{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "compile-java",
            "type": "shell",
            "command": "javac",
            "args": [
                "-d", "bin",            // destination directory
                "src/*.java"         // compile all sources recursively
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always"
            },
            "problemMatcher": [
                "$javac"
            ]
        }
    ]
}